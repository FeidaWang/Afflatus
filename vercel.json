{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.feida.au" }],
      "destination": "https://feida.au/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex" }]
    }
  ]
}
